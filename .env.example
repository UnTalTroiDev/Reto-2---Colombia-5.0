# Optional: Socrata app token for higher rate limits.
# Register one free at https://evergreen.data.socrata.com/profile/edit/developer_settings
# SOCRATA_APP_TOKEN=

# Required for the AI auditor (/auditor): Cerebras inference (Llama 3.3 70B).
# Free tier: ~14,400 req/day. Get a key at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Optional: model override. Available on Cerebras free tier:
#   qwen-3-235b-a22b-instruct-2507  (default — mejor calidad en español)
#   gpt-oss-120b                    (OpenAI OSS, muy rápido)
#   llama3.1-8b                     (más rápido, menor calidad)
# CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
